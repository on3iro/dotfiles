snippet framedFig "Creates a figure env, with an integrated frame"
\begin{figure}
    \begin{mdframed}
       \centering
       \includegraphics[width=\textwidth{}]{$1}
   \end{mdframed}
   \caption{$2}
   \label{$3}
\end{figure}
endsnippet
